{
  "manifest_version": 3,
  "name": "AutoTrader DealScore Overlay",
  "description": "Annotates AutoTrader listings with DealScore based on KBB badge and miles anomaly.",
  "version": "1.3.1",
  "browser_specific_settings": {
    "gecko": {
      "id": "autotrader-dealscore-overlay@atiq.local",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "permissions": [
    "storage"
  ],
  "options_page": "options.html",
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.autotrader.com/*"
      ],
      "js": [
        "contentScript.js"
      ]
    }
  ]
}
